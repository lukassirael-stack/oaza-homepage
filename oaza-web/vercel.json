{
  "redirects": [
    {
      "source": "/:path((?!img/|api/|favicon\\.svg|robots\\.txt|index\\.html|pobyt-ve-svetle|portalova-zahrada).+)",
      "destination": "https://web.oaza-adamanthea.cz/:path",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
