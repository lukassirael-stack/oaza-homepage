{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path((?!img/|api/|favicon|oaza-adamanthea-favicon|robots\\.txt|index\\.html|pobyt-ve-svetle|portalova-zahrada|nabidka-sluzeb|pronajem-prostor|rodove-klice|kraniosakralni-terapie|harmonizace-a-ocista-prostoru|shamballa-zasveceni|terapie-v-oaze|terapie-hojnosti-a-prosperity|karma-minule-zivoty|foceni-aury-a-caker|dalkova-harmonizace-aury|harmonizace-jmena-a-prijmeni|lemoare-krystaly|spoluprace|vesmirny-kod-zrozeni|akce|admin-akce|gdpr|kontakt|prehled-navstevnosti|navstevnost\\.js).+)",
      "destination": "https://web.oaza-adamanthea.cz/:path",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/akce/:slug", "destination": "/akce-detail?slug=:slug" }
  ],
  "crons": [
    { "path": "/api/akce-denni-souhrn", "schedule": "0 6 * * *" }
  ],
  "headers": [
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
