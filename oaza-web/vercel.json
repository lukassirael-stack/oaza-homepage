{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path((?!img/|api/|favicon|oaza-adamanthea-favicon|robots\\.txt|index\\.html|pobyt-ve-svetle|portalova-zahrada|nabidka-sluzeb|pronajem-prostor|rodove-klice|kraniosakralni-terapie|harmonizace-a-ocista-prostoru|shamballa-zasveceni|kontakt).+)",
      "destination": "https://web.oaza-adamanthea.cz/:path",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
