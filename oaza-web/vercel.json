{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.oaza-adamanthea.cz"
        }
      ],
      "destination": "https://oaza-adamanthea.cz/:path*",
      "permanent": true
    },
    {
      "source": "/obchod",
      "destination": "/bali-shop",
      "permanent": true
    },
    {
      "source": "/spirit-shop-1",
      "destination": "/bali-shop",
      "permanent": true
    },
    {
      "source": "/product-page/:cesta*",
      "destination": "/bali-shop",
      "permanent": true
    },
    {
      "source": "/event-details/:cesta*",
      "destination": "/akce",
      "permanent": true
    },
    {
      "source": "/produkt",
      "has": [
        {
          "type": "query",
          "key": "slug",
          "value": "(?<slug>.+)"
        }
      ],
      "destination": "/produkt/:slug",
      "permanent": true
    },
    {
      "source": "/:path((?!img/|api/|favicon|oaza-adamanthea-favicon|robots\\.txt|sitemap\\.xml|sitemap-produkty\\.xml|feed-google\\.xml|feed-zbozi\\.xml|feed-heureka\\.xml|index\\.html|pobyt|pobyt-ve-svetle|portalova-zahrada|nabidka-sluzeb|o-nas|pronajem-prostor|rodove-klice|kraniosakralni-terapie|harmonizace-a-ocista-prostoru|shamballa-zasveceni|terapie-v-oaze|terapie-hojnosti-a-prosperity|karma-minule-zivoty|foceni-aury-a-caker|dalkova-harmonizace-aury|harmonizace-jmena-a-prijmeni|lemoare-krystaly|spoluprace|vesmirny-kod-zrozeni|akce|admin-akce|gdpr|kontakt|prehled-navstevnosti|zdravi|admin-produkty|import-wix|rehost-fotky|obchod|produkt|pokladna|bali-shop|admin-objednavky|kosik\\.js|navstevnost\\.js).+)",
      "has": [
        {
          "type": "host",
          "value": "oaza-adamanthea.cz"
        }
      ],
      "destination": "https://web.oaza-adamanthea.cz/:path",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/akce/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|meta-externalagent|facebookcatalog|Facebot|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Pinterest).*"
        }
      ],
      "destination": "https://rezervace-proxy.vercel.app/api/og?type=akce&slug=:slug"
    },
    {
      "source": "/produkt",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|meta-externalagent|facebookcatalog|Facebot|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Pinterest).*"
        }
      ],
      "destination": "https://rezervace-proxy.vercel.app/api/og?type=produkt"
    },
    {
      "source": "/produkt/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Googlebot|Google-InspectionTool|Storebot-Google|bingbot|SeznamBot|DuckDuckBot|Applebot|YandexBot|facebookexternalhit|meta-externalagent|facebookcatalog|Facebot|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Pinterest).*"
        }
      ],
      "destination": "/api/produkt-render?slug=:slug"
    },
    {
      "source": "/produkt/:slug",
      "destination": "/produkt"
    },
    {
      "source": "/sitemap-produkty.xml",
      "destination": "/api/sitemap-produkty"
    },
    {
      "source": "/feed-google.xml",
      "destination": "/api/feedy?typ=google"
    },
    {
      "source": "/feed-zbozi.xml",
      "destination": "/api/feedy?typ=zbozi"
    },
    {
      "source": "/feed-heureka.xml",
      "destination": "/api/feedy?typ=heureka"
    },
    {
      "source": "/akce/:slug",
      "destination": "/akce-detail?slug=:slug"
    }
  ],
  "crons": [
    {
      "path": "/api/akce-denni-souhrn",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!api/|img/|.*\\.).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
